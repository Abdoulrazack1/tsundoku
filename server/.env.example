# Tsundoku — variables d'environnement (exemple)
NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tsundoku
DB_USER=root
DB_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

UPLOAD_MAX_SIZE=5242880
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

SEED_ADMIN_EMAIL=admin@tsundoku.app
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
