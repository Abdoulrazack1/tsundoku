# Tsundoku — variables d'environnement (exemple)
NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tsundoku
DB_USER=root
DB_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

UPLOAD_MAX_SIZE=5242880
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

SEED_ADMIN_EMAIL=admin@tsundoku.app
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# Intégrations manga
INKO_BASE=http://127.0.0.1:8088/api
ANILIST_USERNAME=

# SEO / Google
# URL publique du site (ex: https://tsundoku.app) — sert aux balises canoniques,
# Open Graph et au sitemap. Laisser vide en local (déduit de la requête).
SITE_URL=
# Code de vérification Google Search Console (balise meta) pour soumettre le site.
GOOGLE_SITE_VERIFICATION=
