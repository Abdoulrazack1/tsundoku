{
  "name": "tsundoku-server",
  "version": "1.0.0",
  "description": "Tsundoku — Journal de lectures. API REST Node/Express/MySQL.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:schema": "node db/run-schema.js",
    "db:seed": "node db/seed.js",
    "db:covers": "node db/generate-covers.js",
    "db:reset": "node db/run-schema.js && node db/seed.js && node db/generate-covers.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand"
  },
  "keywords": [
    "blog",
    "lecture",
    "japanese",
    "awwwards"
  ],
  "author": "Tsundoku",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "msedge-tts": "^2.0.6",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
